# ==============================================================================
# TreinAI - Frontend (.env)
# Copie para `.env` (local) ou configure no painel da Vercel do projeto FRONT.
# ATENCAO: variaveis VITE_ sao embutidas no build — depois de alterar na
# Vercel e preciso fazer um novo deploy (rebuild) para valerem.
# ==============================================================================

# URL do backend (API). SEM barra no final.
VITE_API_URL=https://seu-back.vercel.app

# Chave PUBLICAVEL do Stripe em modo producao (comeca com pk_live_).
# Onde pegar: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxx

# Ambiente
VITE_NODE_ENV=production

# Chave da API de busca de imagens do Google (Configuracoes)
VITE_API_GOOGLE_SEARCH_IMAGES=
