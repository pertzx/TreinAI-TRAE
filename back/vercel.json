{
  "version": 2,
  "builds": [
    {
      "src": "./index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "./index.js"
    }
  ],
  "env": {
    "BLOB_READ_WRITE_TOKEN": "@blob_read_write_token",
    "NODE_ENV": "production",
    "VERCEL": "true"
  },
  "functions": {
    "./index.js": {
      "maxDuration": 30
    }
  }
}
