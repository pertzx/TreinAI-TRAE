# ==============================================================================
# TreinAI - Backend (.env)
# Copie este arquivo para `.env` e preencha os valores reais.
# Em producao (Vercel), configure estas variaveis no painel do projeto:
# Settings > Environment Variables (e faca REDEPLOY depois de alterar).
# ==============================================================================

# ------------------------------------------------------------------------------
# Banco de dados (MongoDB Atlas)
# O index.js monta a URI assim:
# mongodb+srv://DB_USER:DB_PASSWORD@cluster0.vcxrbu2.mongodb.net/DB_NAME
# ------------------------------------------------------------------------------
DB_USER=seu_usuario_atlas
DB_PASSWORD=sua_senha_atlas
DB_NAME=treinai

# Usada apenas pelos scripts (seedPlans, backfills) como fallback
DATABASE_URL=mongodb://localhost:27017/treinai

# ------------------------------------------------------------------------------
# Autenticacao (ATENCAO: o nome correto e SECRET_JWT, nao JWT_SECRET)
# ------------------------------------------------------------------------------
SECRET_JWT=um_segredo_longo_e_aleatorio_aqui

# ------------------------------------------------------------------------------
# STRIPE (MODO PRODUCAO / LIVE)
# Onde pegar: https://dashboard.stripe.com/apikeys (com "Modo de teste" DESLIGADO)
# - STRIPE_SECRET_KEY: comeca com sk_live_
# - STRIPE_WEBHOOK_SECRET: comeca com whsec_ — gerado ao criar o webhook em
#   https://dashboard.stripe.com/webhooks (veja STRIPE_PRODUCAO_SETUP.md)
# ------------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# Price IDs dos PLANOS (crie os produtos/precos na NOVA conta e cole aqui).
# Sao usados pelo script seedPlans.js para gravar na colecao Plan do Mongo.
# Todos recorrentes/mensais em BRL:
#   pro   = R$ 39,99/mes | max = R$ 79,99/mes | coach = R$ 149,99/mes
STRIPE_PRICEID_PRO=price_xxxxxxxxxxxxxxxx
STRIPE_PRICEID_MAX=price_xxxxxxxxxxxxxxxx
STRIPE_PRICEID_COACH=price_xxxxxxxxxxxxxxxx

# Price IDs dos LOCAIS (anuncio de locais). Recorrentes/mensais em BRL:
#   _100 = R$ 100/mes (clinica de fisioterapia, consultorio do nutricionista)
#   _180 = R$ 180/mes (academia, loja)
#   _50  = R$ 50/mes  (outro)
STRIPE_PRICEID_100=price_xxxxxxxxxxxxxxxx
STRIPE_PRICEID_180=price_xxxxxxxxxxxxxxxx
STRIPE_PRICEID_50=price_xxxxxxxxxxxxxxxx

# ------------------------------------------------------------------------------
# OpenAI (IA de treinos / NutriAI / imagens)
# ------------------------------------------------------------------------------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# ------------------------------------------------------------------------------
# Email (Nodemailer / Gmail com senha de app)
# ------------------------------------------------------------------------------
EMAIL_USER=seu_email@gmail.com
EMAIL_PASS=sua_senha_de_app

# ------------------------------------------------------------------------------
# Cloudinary (uploads de imagem em producao)
# ------------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret

# ------------------------------------------------------------------------------
# Ambiente / servidor
# ------------------------------------------------------------------------------
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# URL publica do FRONTEND (usada no CORS e nos redirects do Stripe Checkout:
# success_url / cancel_url). SEM barra no final.
FRONTEND_URL=https://seu-front.vercel.app

# Origens extras permitidas no CORS, separadas por virgula (opcional)
ALLOWED_ORIGINS=https://seu-front.vercel.app

# URL base do proprio backend (usada pelo AnunciosController p/ montar links)
BASEURL=https://seu-back.vercel.app

# ------------------------------------------------------------------------------
# Redis / cache (opcional — se nao tiver Redis, deixe em branco)
# ------------------------------------------------------------------------------
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
MAX_CACHE_SIZE=1000
CACHE_TTL=300

# ------------------------------------------------------------------------------
# Rate limiting / custos de IA (opcionais — possuem defaults no codigo)
# ------------------------------------------------------------------------------
AI_RATE_WINDOW_MS=60000
AI_RATE_MAX=20
IMAGE_RATE_WINDOW_MS=60000
IMAGE_RATE_MAX=5
IMAGE_FIND_RATE_WINDOW_MS=60000
IMAGE_FIND_RATE_MAX=30
IMAGE_GEN_LOCK_MS=30000
IMAGE_TOKEN_COST=1000
