# ===========================================
# CONFIGURAÇÕES BÁSICAS DO SERVIDOR
# ===========================================
URL=http://localhost:4000
PORT=4000
NODE_ENV=development

# ===========================================
# CONFIGURAÇÕES DO BANCO DE DADOS
# ===========================================
DB_USER=seu_usuario_mongodb
DB_PASSWORD=sua_senha_mongodb
DB_NAME=TreinAI

# ===========================================
# CONFIGURAÇÕES DE SEGURANÇA
# ===========================================
# Chave secreta para JWT (OBRIGATÓRIA - GERE UMA NOVA PARA PRODUÇÃO)
SECRET_JWT=sua_chave_jwt_super_secreta_aqui

# Chave secreta para sessões (CSRF Protection)
SESSION_SECRET=sua_chave_secreta_para_sessoes_aqui_muito_forte_e_unica

# URL do frontend para CORS
FRONTEND_URL=http://localhost:5173

# URLs adicionais permitidas em produção (separadas por vírgula)
# Exemplo: ALLOWED_ORIGINS=https://meudominio.com,https://www.meudominio.com,https://app.meudominio.com
ALLOWED_ORIGINS=

# ===========================================
# CONFIGURAÇÕES DA OPENAI
# ===========================================
OPENAI_API_KEY=sua_chave_openai_aqui
OPENAI_MODEL=gpt-4o-mini

# ===========================================
# CONFIGURAÇÕES DE APIs EXTERNAS
# ===========================================
EXERCISEDB_API_KEY=sua_chave_exercisedb_aqui

# ===========================================
# CONFIGURAÇÕES DE EMAIL
# ===========================================
EMAIL_USER=seu_email@gmail.com
EMAIL_PASS=sua_senha_de_app_gmail

# ===========================================
# CONFIGURAÇÕES DO STRIPE
# ===========================================
STRIPE_SECRET_KEY=sua_chave_secreta_stripe
STRIPE_WEBHOOK_SECRET=seu_webhook_secret_stripe

# ===========================================
# CONFIGURAÇÕES DO REDIS (OPCIONAL)
# ===========================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ===========================================
# CONFIGURAÇÕES DE PRODUÇÃO
# ===========================================
# Para produção, altere NODE_ENV para 'production'
# NODE_ENV=production
# FRONTEND_URL=https://seudominio.com
# ALLOWED_ORIGINS=https://seudominio.com,https://www.seudominio.com