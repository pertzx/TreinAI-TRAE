# Configurações do Banco de Dados
DATABASE_URL=mongodb://localhost:27017/treinai

# Configurações JWT
JWT_SECRET=seu_jwt_secret_aqui

# Configurações de Email
EMAIL_USER=seu_email@gmail.com
EMAIL_PASS=sua_senha_app

# Configurações do Stripe
STRIPE_SECRET_KEY=sk_test_sua_chave_secreta_aqui
STRIPE_PUBLISHABLE_KEY=pk_test_sua_chave_publica_aqui
STRIPE_WEBHOOK_SECRET=whsec_sua_webhook_secret_aqui

# Configurações do Cloudinary (para uploads em produção)
CLOUDINARY_CLOUD_NAME=seu_cloud_name_aqui
CLOUDINARY_API_KEY=sua_api_key_aqui
CLOUDINARY_API_SECRET=seu_api_secret_aqui

# Configurações de Ambiente
NODE_ENV=development
PORT=3000

# Configurações de CORS
FRONTEND_URL=http://localhost:5173
# Lista de domínios permitidos separados por vírgula (apenas para produção)
# Exemplo: ALLOWED_ORIGINS=https://meudominio.com,https://www.meudominio.com,https://app.meudominio.com
ALLOWED_ORIGINS=

# Configurações de Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Configurações de Segurança
CSRF_SECRET=seu_csrf_secret_aqui
SESSION_SECRET=seu_session_secret_aqui